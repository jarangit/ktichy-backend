meta {
  name: Approve Pairing Request
  type: http
  seq: 1
}

patch {
  url: {{baseUrl}}/pairing-requests/{{pairingRequestId}}/approve
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "stationId": "{{stationId}}",
    "alias": "hot-kitchen-display-1"
  }
}
