meta {
  name: Create Device
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/devices
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "deviceId": "{{deviceExternalId}}",
    "deviceName": "Kitchen Tablet",
    "fingerprint": "fp_local_001",
    "storeId": "{{storeId}}",
    "stationId": "{{stationId}}",
    "appVersion": "1.0.0"
  }
}
